# .env.example — copy to .env and fill in values
# --- AI Provider ---
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Optional fallback providers. Leave blank unless you explicitly select them.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Database ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=finsight
POSTGRES_USER=finsight
POSTGRES_PASSWORD=finsight_dev
DATABASE_URL=postgresql+asyncpg://finsight:finsight_dev@postgres:5432/finsight

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_VECTOR_SIZE=3072

# --- App Security ---
JWT_SECRET=change_this_in_production_use_a_long_random_string

# --- File Storage ---
UPLOAD_DIR=/app/uploads

# --- Model Selection ---
GENERATION_MODEL=gemini-2.5-flash-lite
UTILITY_MODEL=gemini-2.5-flash-lite
GRADER_MODEL=gemini-2.5-flash-lite
PAL_MODEL=gemini-2.5-flash-lite
EMBEDDING_MODEL=gemini-embedding-001
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Voice ---
STT_MODEL=gemini-2.5-flash-lite
TTS_MODEL=gemini-3.1-flash-tts-preview
TTS_VOICE=Kore
VAD_SILENCE_BYTES=32000

# --- Pipeline Configuration ---
RETRIEVAL_THRESHOLD=0.5
CHAT_HISTORY_LIMIT=6
SUPPORTED_LANGUAGES=en,hi,gu,mr
CHART_KEYWORDS=revenue,growth,trend,chart,plot,quarterly,annual
TABLE_KEYWORDS=table,compare,list,segments,breakdown,distribution

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Feature Flags ---
ENABLE_PROMPT_CACHING=true
ENABLE_SLM_COMPRESSION=true
ENABLE_VOICE=true
DEBUG_MODE=false
